{
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["ext/workspaces"],
    "modules-center": ["custom/music"],
    "modules-right": ["tray", "pulseaudio", "backlight", "clock", "custom/lock"],
    "ext/workspaces": {
         "on-click": "activate",
         "sort-by-name": true,
         "format": "{name}",
         "format-icons": {
             "default": "о®ҙ"
         }
     },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "custom/music": {
        "format": "{icon} {text}",
        "return-type": "json",
        "format-icons": {
            "Playing": "пҖҒ ", // Music notes icon when playing
            "Paused": "у°ҸӨ "   // Pause icon when paused
        },
        "exec": "playerctl metadata --format '{\"text\": \"{{artist}} - {{title}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' 2>/dev/null",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "interval": 2
    },
    "clock": {
        "timezone": "Australia/Melbourne",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%d %B %Y at %I:%M %p}",
        "format-alt": "у°ғӯ {:%A, %b %d  Week %W  уұҗ® %I:%M:%S %p}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "п–ғ",
        "format-plugged": "п–ғ",
        "format-alt": "{icon}",
        "format-icons": ["п–Ӯ", "п•№",  "п•ә", "п•»", "п•ј", "п•Ҫ", "п•Ҫ", "п•ҫ", "п•ҝ", "п–Җ", "п–Ғ", "п•ё"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-muted": "п‘Ұ",
        "format-icons": {
            "default": ["пҖҰ", "пҖ§", "пҖЁ "]
        },
        "on-click": "pavucontrol"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "wlogout",
        "format": "пҖЈ",
    },
}
