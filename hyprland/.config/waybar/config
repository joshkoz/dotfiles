{
    "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["ext/workspaces"],
    "modules-center": ["custom/music"],
    "modules-right": ["tray", "pulseaudio", "backlight", "clock"],
    "ext/workspaces": {
         "on-click": "activate",
         "sort-by-name": true,
         "format": "{name}",
         "format-icons": {
             "default": "о®ґ"
         }
     },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "custom/music": {
        "format": "{icon} {text}",
        "return-type": "json",
        "format-icons": {
            "Playing": "пЂЃ ", // Music notes icon when playing
            "Paused": "у°Џ¤ "   // Pause icon when paused
        },
        "exec": "playerctl metadata --format '{\"text\": \"{{artist}} - {{title}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' 2>/dev/null",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "interval": 2
    },
    "clock": {
        "timezone": "Australia/Melbourne",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%d %B %Y at %I:%M %p}",
        "format-alt": "у°ѓ­ {:%A, %b %d  Week %W  у±ђ® %I:%M:%S %p}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "п–ѓ",
        "format-plugged": "п–ѓ",
        "format-alt": "{icon}",
        "format-icons": ["п–‚", "п•№",  "п•є", "п•»", "п•ј", "п•Ѕ", "п•Ѕ", "п•ѕ", "п•ї", "п–Ђ", "п–Ѓ", "п•ё"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-muted": "п‘¦",
        "format-icons": {
            "default": ["пЂ¦", "пЂ§", "пЂЁ "]
        },
